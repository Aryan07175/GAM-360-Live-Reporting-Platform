# .env.example — GAM 360 Live Reporting Platform Configuration

# --- GAM 360 ---
GAM_NETWORK_CODE=your_network_code_here
GAM_API_VERSION=v202602
# Path to your googleads.yaml
GAM_CREDENTIALS_PATH=config/googleads.yaml

# --- Live Reporting ---
# Request timeout in seconds for GAM report generation
GAM_REQUEST_TIMEOUT=120
# Maximum parallel GAM report requests
GAM_MAX_PARALLEL_REQUESTS=5
# Set to true to print revenue values in micros (raw from API) instead of dollars
REVENUE_IN_MICROS=false

# --- MCP Server ---
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# --- Ask GAM 360 Chat (AWS Bedrock) ---
# Create an IAM user with AmazonBedrockFullAccess and generate an access key.
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# AWS region where Bedrock is available (e.g. us-east-1, us-west-2)
AWS_REGION=us-east-1
# Bedrock model ID — must be enabled in your AWS Bedrock console under Model access.
# Recommended: anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Alerts (optional) ---
SLACK_WEBHOOK_URL=
# Revenue drop threshold % that triggers an alert (e.g. 20 = 20% drop)
ANOMALY_THRESHOLD_PCT=20
